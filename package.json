{
  "name": "codino",
  "version": "1.0.0",
  "description": "A narrative-driven coding education game for children aged 7-8. Learn programming through personalized storytelling with AI-generated challenges.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:grammar": "lezer-generator src/core/language/codino.grammar -o src/core/language/parser.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "education",
    "coding",
    "children",
    "programming",
    "learning",
    "game",
    "ai",
    "claude",
    "storytelling",
    "interactive",
    "bilingual",
    "italian",
    "english",
    "lezer",
    "parser",
    "interpreter"
  ],
  "author": "Alessio Treglia",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/alessio/codino.git"
  },
  "homepage": "https://alessio.github.io/codino/",
  "bugs": {
    "url": "https://github.com/alessio/codino/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^1.6.1"
  }
}
