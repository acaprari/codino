{
  "name": "codino",
  "version": "1.0.0",
  "description": "A narrative-driven coding education game for children aged 7-8. Learn programming through personalized storytelling with AI-generated challenges.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:grammar": "lezer-generator src/core/language/codino.grammar -o src/core/language/parser.ts && node -e \"const f='src/core/language/parser.ts';const fs=require('fs');const c=fs.readFileSync(f,'utf8');if(!c.includes('@ts-nocheck'))fs.writeFileSync(f,c.replace(/^(\\/\\/[^\\n]*\\n)/,'$1// @ts-nocheck\\n'))\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "education",
    "coding",
    "children",
    "programming",
    "learning",
    "game",
    "ai",
    "claude",
    "storytelling",
    "interactive",
    "bilingual",
    "italian",
    "english",
    "lezer",
    "parser",
    "interpreter"
  ],
  "author": "Alessio Caprari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acaprari/codino.git"
  },
  "homepage": "https://acaprari.github.io/codino/",
  "bugs": {
    "url": "https://github.com/acaprari/codino/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
