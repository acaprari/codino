# Codino - Environment Variables Example
#
# Copy this file to .env.local and add your actual values
# Note: .env.local is in .gitignore and will not be committed

# Optional: Anthropic API key for development testing
# In production, users enter their own key via the Settings screen
# Get your key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
